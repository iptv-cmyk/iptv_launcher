<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content: toolbar and video player with overlay controls -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Container for the video player and overlay controls -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/backgroundImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Media3 player view -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                app:surface_type="texture_view"
                app:shutter_background_color="@android:color/transparent"
                app:show_buffering="when_playing"
                app:show_shuffle_button="false"
                app:resize_mode="fit"
                app:use_controller="false" />

            <!-- YouTube Player View -->
            <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                android:id="@+id/youtubePlayerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:enableAutomaticInitialization="false" />

            <!-- Overlay text for showing channel name/number (OSD). Initially hidden. -->
            <TextView
                android:id="@+id/osdText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#66000000"
                android:padding="8dp"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:visibility="gone" />

            <RelativeLayout
                android:id="@+id/welcomeStateContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <!-- Top Left Time and Date -->
                <LinearLayout
                    android:id="@+id/dateTimeContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginEnd="24dp"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <TextClock
                        android:id="@+id/timeClock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:format12Hour="h:mm a"
                        android:format24Hour="HH:mm"
                        android:textColor="@android:color/white"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-light"
                        android:shadowColor="#80000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="4" />

                    <TextClock
                        android:id="@+id/dateClock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:format12Hour="EEEE, MMMM d, yyyy"
                        android:format24Hour="EEEE, MMMM d, yyyy"
                        android:textColor="#E0E0E0"
                        android:textSize="12sp"
                        android:shadowColor="#80000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="4" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/emptyStateContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@android:color/transparent"
                    android:padding="16dp">

                    <ProgressBar
                        android:id="@+id/serviceDiscoveryProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:indeterminateTint="@android:color/white" />

                    <LinearLayout
                        android:id="@+id/waitingForChannelContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/waitingChannelIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_list" />

                        <TextView
                            android:id="@+id/emptyStateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/channels_ready"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />
                    </LinearLayout>
                </LinearLayout>

            </RelativeLayout>

            <!-- Bottom Buttons (Floating Overlay) -->
            <LinearLayout
                android:id="@+id/floatingButtonsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:padding="8dp">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/channelsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp"
                    app:srcCompat="@drawable/ic_list"
                    app:tint="@null"
                    app:backgroundTint="@color/fab_bg_color"
                    app:borderWidth="3dp"
                    app:fabCustomSize="64dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusRight="@+id/youtubeButton"
                    android:nextFocusForward="@+id/youtubeButton"
                    android:contentDescription="Channels" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/youtubeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp"
                    app:srcCompat="@drawable/ic_youtube"
                    app:tint="@null"
                    app:backgroundTint="@color/fab_bg_color"
                    app:borderWidth="3dp"
                    app:fabCustomSize="64dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/channelsButton"
                    android:nextFocusRight="@+id/netflixButton"
                    android:nextFocusForward="@+id/netflixButton"
                    android:contentDescription="YouTube" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/netflixButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp"
                    app:srcCompat="@drawable/netflix_logo"
                    app:tint="@null"
                    app:backgroundTint="@color/fab_bg_color"
                    app:borderWidth="3dp"
                    app:fabCustomSize="64dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/youtubeButton"
                    android:nextFocusRight="@+id/settingsButton"
                    android:nextFocusForward="@+id/settingsButton"
                    android:contentDescription="Netflix" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/settingsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp"
                    app:srcCompat="@drawable/ic_settings"
                    app:tint="@color/fab_icon_color"
                    app:backgroundTint="@color/fab_bg_color"
                    app:borderWidth="3dp"
                    app:fabCustomSize="64dp"
                    android:focusable="true"
                    android:visibility="gone"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/netflixButton"
                    android:nextFocusRight="@+id/aboutButton"
                    android:nextFocusForward="@+id/aboutButton"
                    android:contentDescription="Settings" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/aboutButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/v_logo"
                    app:tint="@null"
                    app:backgroundTint="@color/fab_bg_color"
                    app:borderWidth="3dp"
                    app:fabCustomSize="64dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/settingsButton"
                    android:contentDescription="About" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- Drawer containing the channel list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelRecyclerView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:scrollbars="vertical"
        android:background="@color/channelListBackground"
        android:focusable="true"
        android:focusableInTouchMode="true" />

</androidx.drawerlayout.widget.DrawerLayout>
